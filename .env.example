NODE_ENV=development
PORT=3000
MONGO_URI=mongodb://127.0.0.1:27017/vidyarupa_discovery
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_EMAIL=admin@vidyarupa.edu
ADMIN_PASSWORD=replace-with-a-strong-password
ADMIN_NOTIFY_EMAIL=manager@vidyarupa.edu

# Optional SMTP settings for booking notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Vidyarupa Discovery <no-reply@vidyarupa.edu>"
